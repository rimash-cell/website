{
  "id": "blog_post",
  "label": "Blog Post",
  "repeatable": true,
  "status": true,
  "json": {
    "Main": {
      "uid": {
        "type": "UID",
        "config": {
          "label": "Slug",
          "placeholder": "unique-post-id"
        }
      },
      "title": {
        "type": "StructuredText",
        "config": {
          "label": "Title",
          "single": "heading1"
        }
      },
      "summary": {
        "type": "Text",
        "config": {
          "label": "Summary"
        }
      },
      "body": {
        "type": "StructuredText",
        "config": {
          "label": "Body",
          "multi": "paragraph,heading2,heading3,em,strong,hyperlink,list-item,o-list-item"
        }
      },
      "hero_image": {
        "type": "Image",
        "config": {
          "label": "Hero Image",
          "constraint": {},
          "thumbnails": []
        }
      },
      "published_date": {
        "type": "Date",
        "config": {
          "label": "Published Date"
        }
      }
    },
    "Settings": {
      "order": {
        "type": "Number",
        "config": {
          "label": "Order",
          "placeholder": "Order (lower first)"
        }
      },
      "hidden": {
        "type": "Boolean",
        "config": {
          "label": "Hidden",
          "placeholder_false": "Visible",
          "placeholder_true": "Hidden",
          "default_value": false
        }
      }
    }
  }
}