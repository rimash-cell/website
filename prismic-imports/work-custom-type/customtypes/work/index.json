{
  "id": "work",
  "label": "Work",
  "repeatable": true,
  "status": true,
  "json": {
    "Main": {
      "uid": {
        "type": "UID",
        "config": {
          "label": "Slug",
          "placeholder": "unique-project-id"
        }
      },
      "title": {
        "type": "StructuredText",
        "config": {
          "label": "Project Name",
          "placeholder": "Project Title",
          "allowTargetBlank": true,
          "single": "heading1"
        }
      },
      "category": {
        "type": "Select",
        "config": {
          "label": "Category",
          "options": [
            "Luxury Retail",
            "Hospitality",
            "Experiential Spaces",
            "Residential",
            "Other"
          ]
        }
      },
      "main_image": {
        "type": "Image",
        "config": { "label": "Main Image", "constraint": {}, "thumbnails": [] }
      },
      "preview_image": {
        "type": "Image",
        "config": { "label": "Preview Image", "constraint": {}, "thumbnails": [] }
      },
      "intro": {
        "type": "StructuredText",
        "config": { "label": "Intro / Description", "multi": "paragraph,em,strong,hyperlink" }
      },
      "client": { "type": "Text", "config": { "label": "Client", "placeholder": "Client Name" } },
      "year": { "type": "Text", "config": { "label": "Year", "placeholder": "2024" } },
      "location": { "type": "Text", "config": { "label": "Location", "placeholder": "Dubai, UAE" } },
      "core_identity": {
        "type": "Group",
        "config": {
          "label": "Core Identity",
          "fields": {
            "project_title": { "type": "StructuredText", "config": { "label": "Project Title", "single": "heading1" } },
            "concept_title": { "type": "Text", "config": { "label": "Concept Title" } },
            "project_type": { "type": "Select", "config": { "label": "Project Type", "options": [
              "Retail Experience",
              "Interior / Spatial Design",
              "Event / Installation",
              "360 Campaign",
              "Product Development / Packaging",
              "Concept / Exploration"
            ] } },
            "client": { "type": "Text", "config": { "label": "Client" } },
            "year": { "type": "Text", "config": { "label": "Year" } },
            "location": { "type": "Text", "config": { "label": "Location" } },
            "my_role": { "type": "Text", "config": { "label": "My Role" } },
            "context_tags": { "type": "Tags", "config": { "label": "Context / Format", "options": ["Hospitality", "Residential", "Flagship", "Popup"] } }
          }
        }
      },
      "concept_and_narrative": {
        "type": "Group",
        "config": {
          "label": "Concept & Narrative",
          "fields": {
            "concept_narrative_short": { "type": "StructuredText", "config": { "label": "Concept Narrative (Short)", "multi": "paragraph,em,strong,hyperlink" } },
            "concept_narrative_full": { "type": "StructuredText", "config": { "label": "Concept Narrative (Full)", "multi": "paragraph,heading2,heading3,em,strong,hyperlink,list-item,o-list-item" } },
            "strategic_insight": { "type": "StructuredText", "config": { "label": "Strategic Insight" } },
            "brand_decoding": { "type": "StructuredText", "config": { "label": "Brand Decoding" } },
            "brand_concept_link": { "type": "StructuredText", "config": { "label": "Brand-Concept Link" } },
            "narrative_architecture": { "type": "StructuredText", "config": { "label": "Narrative Architecture" } }
          }
        }
      },
      "story_chapters": {
        "type": "Group",
        "config": { "label": "Story Chapters", "fields": { "chapter_title": { "type": "Text", "config": { "label": "Chapter Title" } }, "chapter_body": { "type": "StructuredText", "config": { "label": "Chapter Body", "multi": "paragraph,em,strong,hyperlink" } } } }
      },
      "hero_image": { "type": "Image", "config": { "label": "Hero Image", "constraint": {}, "thumbnails": [] } },
      "execution_images": { "type": "Group", "config": { "label": "Execution Images (real photos)", "fields": { "image": { "type": "Image", "config": { "label": "Photo", "constraint": {}, "thumbnails": [] } }, "caption": { "type": "Text", "config": { "label": "Caption" } } } },
      "design_images": { "type": "Group", "config": { "label": "Design Images (renders)", "fields": { "image": { "type": "Image", "config": { "label": "Render", "constraint": {}, "thumbnails": [] } }, "note": { "type": "Text", "config": { "label": "Note" } } } },
      "process_images": { "type": "Group", "config": { "label": "Process Images", "fields": { "image": { "type": "Image", "config": { "label": "Process Image", "constraint": {}, "thumbnails": [] } }, "caption": { "type": "Text", "config": { "label": "Caption" } } } },
      "layouts_plans": { "type": "Group", "config": { "label": "Layouts / Plans", "fields": { "plan": { "type": "Image", "config": { "label": "Plan Image", "constraint": {}, "thumbnails": [] } }, "description": { "type": "Text", "config": { "label": "Description" } } } },
      "videos": { "type": "Group", "config": { "label": "Videos (upload or embed)", "fields": { "video_file": { "type": "File", "config": { "label": "Video File" } }, "video_embed": { "type": "Embed", "config": { "label": "Video Embed" } } } },
      "slices": { "type": "Slices", "fieldset": "Slice Zone", "config": { "choices": { "hero": { "type": "SharedSlice" }, "image_gallery": { "type": "SharedSlice" }, "content_block": { "type": "SharedSlice" } } } }
    },
    "Settings": {
      "order": { "type": "Number", "config": { "label": "Order", "placeholder": "Order (lower first)" } },
      "hidden": { "type": "Boolean", "config": { "label": "Hidden", "placeholder_false": "Visible", "placeholder_true": "Hidden", "default_value": false } },
      "featured": { "type": "Boolean", "config": { "label": "Featured", "placeholder_false": "Regular", "placeholder_true": "Featured", "default_value": false } }
    }
  }
}