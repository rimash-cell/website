---
import Layout from "../../layouts/Layout.astro";
import { client } from "../../lib/prismic";
import { SliceZone } from "../../components/SliceZone";
import { PrismicRichText } from "@prismicio/react";

export async function getStaticPaths() {
    const allWorks = await client.getAllByType("work", { lang: "*" });
    return allWorks.map((work) => ({
        params: { uid: work.uid },
    }));
}

const { uid } = Astro.params;

let work;
try {
    work = await client.getByUID("work", uid as string, { lang: "*" });
} catch (e) {
    return Astro.redirect("/404");
}

const {
    title,
    intro,
    client: clientName,
    year,
    location,
    category,
    main_image,
    slices,
} = work.data;

// Fetch next project (simple logic for now)
let nextWork;
try {
    const allWorks = await client.getAllByType("work", {
        lang: "*",
        orderings: { field: "my.work.year", direction: "desc" },
    });
    const currentIndex = allWorks.findIndex((w) => w.uid === uid);
    nextWork = allWorks[(currentIndex + 1) % allWorks.length];
} catch (e) {}
---

<Layout title={`${title?.[0]?.text || "Project"} | Rima Alshoufi`}>
    <article class="animate-fade-in">
        {/* Header Section */}
        <header class="pt-32 pb-24 px-8 md:px-12 max-w-7xl mx-auto">
            <div class="mb-12">
                <a
                    href="/work"
                    class="text-[10px] uppercase tracking-[0.3em] text-gray-500 hover:text-white transition-colors no-underline"
                >
                    &larr; Back to selection
                </a>
            </div>

            <div
                class="flex flex-col md:flex-row justify-between items-end gap-12 mb-20"
            >
                <div class="max-w-4xl">
                    <div
                        class="text-[10px] uppercase tracking-[0.4em] text-purple-400 mb-6 font-bold"
                    >
                        {category}
                    </div>
                    <h1
                        class="text-6xl md:text-8xl font-serif mb-0 leading-[0.9] tracking-tighter"
                    >
                        <PrismicRichText field={title} />
                    </h1>
                </div>
                <div class="text-right hidden md:block">
                    <div class="text-[40px] font-serif opacity-30 italic">
                        {year}
                    </div>
                </div>
            </div>

            <div
                class="grid grid-cols-2 md:grid-cols-4 gap-8 border-t border-white/10 pt-12 text-[10px] tracking-[0.2em] uppercase font-medium"
            >
                <div>
                    <span class="block text-gray-600 mb-4 tracking-[0.3em]"
                        >Client</span
                    >
                    <span class="text-gray-300">{clientName}</span>
                </div>
                <div>
                    <span class="block text-gray-600 mb-4 tracking-[0.3em]"
                        >Region</span
                    >
                    <span class="text-gray-300">{location}</span>
                </div>
                <div>
                    <span class="block text-gray-600 mb-4 tracking-[0.3em]"
                        >Year</span
                    >
                    <span class="text-gray-300">{year}</span>
                </div>
                <div class="md:text-right">
                    <span class="block text-gray-600 mb-4 tracking-[0.3em]"
                        >Sector</span
                    >
                    <span class="text-gray-300">{category}</span>
                </div>
            </div>
        </header>

        {/* Hero Image */}
        <div
            class="w-full aspect-[21/9] bg-[#111] overflow-hidden mb-32 group relative"
        >
            {
                main_image?.url && (
                    <img
                        src={main_image.url}
                        alt={main_image.alt || ""}
                        class="w-full h-full object-cover transition-transform duration-[2s] group-hover:scale-105"
                    />
                )
            }
            <div class="absolute inset-0 bg-black/20"></div>
        </div>

        {/* Intro Content */}
        <div class="px-8 md:px-12 max-w-4xl mx-auto mb-32">
            <div
                class="prose prose-invert prose-2xl prose-p:font-light prose-p:leading-relaxed prose-p:text-gray-300 prose-strong:text-white prose-em:text-purple-400"
            >
                <PrismicRichText field={intro} />
            </div>
        </div>

        {/* Slices (Gallery, etc) */}
        <div class="space-y-32">
            <SliceZone slices={slices} client:load />
        </div>

        {/* Next Project Navigation */}
        {
            nextWork && (
                <section class="py-48 px-8 md:px-12 border-t border-white/5 mt-32 relative overflow-hidden group">
                    <div class="max-w-7xl mx-auto text-center relative z-10">
                        <span class="text-[10px] uppercase tracking-[0.4em] text-gray-500 mb-12 block">
                            Next Project
                        </span>
                        <a
                            href={`/work/${nextWork.uid}`}
                            class="no-underline text-white block"
                        >
                            <h2 class="text-5xl md:text-[8vw] font-serif leading-[0.8] tracking-tighter hover:italic transition-all duration-700">
                                {nextWork.data.title?.[0]?.text}
                            </h2>
                        </a>
                    </div>

                    {/* Background Peek */}
                    {nextWork.data.main_image?.url && (
                        <div class="absolute inset-0 -z-10 opacity-0 group-hover:opacity-20 transition-opacity duration-1000 scale-110 group-hover:scale-100">
                            <img
                                src={nextWork.data.main_image.url}
                                alt=""
                                class="w-full h-full object-cover grayscale"
                            />
                        </div>
                    )}
                </section>
            )
        }
    </article>
</Layout>

<style is:global>
    @keyframes fadeIn {
        from {
            opacity: 0;
        }
        to {
            opacity: 1;
        }
    }
    .animate-fade-in {
        animation: fadeIn 1.5s ease-out forwards;
    }
</style>
