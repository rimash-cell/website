---
import Layout from "../../layouts/Layout.astro";
import { client } from "../../lib/prismic";
import ProjectList from "../../components/ProjectList";

let works: any[] = [];
try {
    works = await client.getAllByType("work", {
        lang: "*",
        orderings: {
            field: "my.work.order",
            direction: "asc",
        },
    });

    // PILOT MOCK: Inject the KHT project into the Prismic results
    works.push({
        uid: "kht-the-perfumers",
        data: {
            title: [{ type: "heading1", text: "The Perfumers", spans: [] }],
            category: "Events & Activations",
            year: "2023",
            hidden: false,
            main_image: {
                url: "/projects/kht-the-perfumers/1_the_perfumers_banner.jpg"
            }
        }
    });
    works = works.filter((w) => !w.data.hidden);
} catch (e) {
    console.error("Failed to fetch works", e);
}
---

<Layout title="Work | Rima Alshoufi">
    <main class="pt-32 px-8 md:px-12 max-w-7xl mx-auto">
        <ProjectList client:load initialWorks={works} />

        {/* ── Static case studies (no Prismic required) ── */}
        <div class="grid grid-cols-1 md:grid-cols-2 gap-x-16 gap-y-32 mt-32 border-t border-black/5 dark:border-white/5 pt-32">
            <a
                href="/work/emovation-lab"
                class="group block animate-fade-in-up"
                style="animation-delay: 0.2s;"
            >
                <div class="relative aspect-[4/3] overflow-hidden bg-neutral-100 dark:bg-[#111] mb-8 group-hover:shadow-2xl transition-shadow duration-700">
                    <img
                        src="/projects/emovation-lab/render-04.jpg"
                        alt="Emovation Lab"
                        class="object-cover w-full h-full transition-transform duration-1000 group-hover:scale-110 ease-out"
                    />
                    <div class="absolute inset-0 bg-black/10 dark:bg-black/40 group-hover:bg-transparent dark:group-hover:bg-black/10 transition-colors duration-700"></div>
                    <div class="absolute bottom-8 left-8 text-white opacity-0 translate-y-4 group-hover:opacity-100 group-hover:translate-y-0 transition-all duration-500 text-[10px] uppercase tracking-[0.3em] font-bold drop-shadow-md">
                        View Project
                    </div>
                </div>
                <div class="flex flex-col gap-4">
                    <div class="flex justify-between items-baseline border-b border-black/10 dark:border-white/10 pb-4">
                        <h2 class="text-2xl md:text-3xl text-neutral-900 dark:text-white group-hover:text-neutral-500 dark:group-hover:text-gray-300 transition-colors duration-300">
                            Emovation Lab
                        </h2>
                        <span class="text-[10px] uppercase tracking-[0.2em] text-neutral-500 dark:text-gray-500">
                            2021
                        </span>
                    </div>
                    <div class="text-[11px] tracking-[0.15em] uppercase text-neutral-500 dark:text-gray-500 font-light">
                        Innovation · Spatial Strategy
                    </div>
                </div>
            </a>
        </div>
    </main>
</Layout>

<style>
    @keyframes fadeInUp {
        from {
            opacity: 0;
            transform: translateY(30px);
        }
        to {
            opacity: 1;
            transform: translateY(0);
        }
    }

    .animate-fade-in-up {
        opacity: 0;
        animation: fadeInUp 1.2s cubic-bezier(0.16, 1, 0.3, 1) forwards;
    }

    .delay-100 {
        animation-delay: 0.1s;
    }
    .delay-200 {
        animation-delay: 0.2s;
    }
</style>
